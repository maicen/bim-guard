# Copy this file to .env and fill in real values
# Windows PowerShell:
#   Copy-Item example.env .env

# Required for Gemini via LiteLLM
GEMINI_API_KEY=
# Alternative key name supported by LiteLLM/Gemini
GOOGLE_API_KEY=

# Optional: override default model used in rule extraction
# Default in code: gemini/gemini-2.0-flash
BIM_GUARD_RULE_MODEL=gemini/gemini-2.0-flash
